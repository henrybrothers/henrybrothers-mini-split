---
import { site } from '@/data/site';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

interface Props {
  overrideCity?: string;
  overrideState?: string;
  overrideStateAbbr?: string;
  overrideLat?: number;
  overrideLng?: number;
}

const {
  overrideCity,
  overrideState,
  overrideStateAbbr,
  overrideLat,
  overrideLng,
} = Astro.props;

const reader = createReader(process.cwd(), keystaticConfig);
const nap = await reader.singletons.businessInfo.read();

const businessName = nap?.businessName ?? 'Henry Brothers Heat \u2022 Cool \u2022 Mini Splits';
const phoneDisplay = nap?.phone ?? '812-994-1008';
const phoneE164 = '+1' + phoneDisplay.replace(/\D/g, '');
const monSatHours = nap?.mondaySaturday ?? 'Open 24 hours';
const sunHours = nap?.sunday ?? 'Closed';

const city = overrideCity ?? site.address.city;
const state = overrideStateAbbr ?? site.address.state;
const lat = overrideLat ?? site.geo.latitude;
const lng = overrideLng ?? site.geo.longitude;

// Build openingHoursSpecification
function parseHours(hoursStr: string): { opens: string; closes: string } | null {
  if (hoursStr.toLowerCase() === 'closed') return null;
  if (hoursStr.toLowerCase().includes('24 hours')) return { opens: '00:00', closes: '23:59' };
  // Parse "9:00 AM – 6:00 PM" style
  const match = hoursStr.match(/(\d+:\d+)\s*(AM|PM)?\s*[–-]\s*(\d+:\d+)\s*(AM|PM)?/i);
  if (!match) return { opens: '00:00', closes: '23:59' };
  const to24 = (t: string, ampm?: string) => {
    const [h, m] = t.split(':').map(Number);
    const isPm = ampm?.toUpperCase() === 'PM';
    return `${String(isPm && h !== 12 ? h + 12 : !isPm && h === 12 ? 0 : h).padStart(2, '0')}:${String(m).padStart(2, '0')}`;
  };
  return { opens: to24(match[1], match[2]), closes: to24(match[3], match[4]) };
}

const monSatSpec = parseHours(monSatHours);
const sunSpec = parseHours(sunHours);

const openingHoursSpecification = [
  ...(monSatSpec ? [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: monSatSpec.opens,
    closes: monSatSpec.closes,
  }] : []),
  ...(sunSpec ? [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Sunday'],
    opens: sunSpec.opens,
    closes: sunSpec.closes,
  }] : []),
];

const areaServed = [
  // Clark County
  { '@type': 'City', name: 'Charlestown', addressRegion: 'IN' },
  { '@type': 'City', name: 'Clarksville', addressRegion: 'IN' },
  { '@type': 'City', name: 'Jeffersonville', addressRegion: 'IN' },
  { '@type': 'City', name: 'Sellersburg', addressRegion: 'IN' },
  { '@type': 'City', name: 'Henryville', addressRegion: 'IN' },
  { '@type': 'City', name: 'Borden', addressRegion: 'IN' },
  { '@type': 'City', name: 'Utica', addressRegion: 'IN' },
  { '@type': 'City', name: 'Otisco', addressRegion: 'IN' },
  { '@type': 'City', name: 'Marysville', addressRegion: 'IN' },
  { '@type': 'City', name: 'Memphis', addressRegion: 'IN' },
  { '@type': 'City', name: 'New Pekin', addressRegion: 'IN' },
  // Floyd County
  { '@type': 'City', name: 'New Albany', addressRegion: 'IN' },
  { '@type': 'City', name: 'Georgetown', addressRegion: 'IN' },
  { '@type': 'City', name: 'Floyds Knobs', addressRegion: 'IN' },
];

const data = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': site.url,
  'name': businessName,
  'alternateName': site.shortName,
  'description': site.description,
  'url': site.url,
  'telephone': phoneE164,
  'email': site.email,
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': city,
    'addressRegion': state,
    'postalCode': site.address.zip,
    'addressCountry': site.address.country,
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': lat,
    'longitude': lng,
  },
  'areaServed': areaServed,
  'serviceArea': {
    '@type': 'GeoCircle',
    'geoMidpoint': { '@type': 'GeoCoordinates', 'latitude': site.geo.latitude, 'longitude': site.geo.longitude },
    'geoRadius': site.serviceRadius,
  },
  'openingHoursSpecification': openingHoursSpecification,
  'priceRange': '$$',
  'paymentAccepted': 'Cash, Credit Card, Check, Financing Available',
  'currenciesAccepted': 'USD',
  'aggregateRating': { '@type': 'AggregateRating', 'ratingValue': '5.0', 'reviewCount': '3', 'bestRating': '5', 'worstRating': '1' },
  'hasOfferCatalog': {
    '@type': 'OfferCatalog',
    'name': 'Ductless HVAC Services',
    'itemListElement': [
      { '@type': 'Offer', 'itemOffered': { '@type': 'Service', 'name': 'Mini Split Installation', 'description': 'Professional installation of ductless mini split systems' } },
      { '@type': 'Offer', 'itemOffered': { '@type': 'Service', 'name': 'Clean and Check\u2120', 'description': 'Seasonal maintenance and tune-up service for ductless systems' } },
      { '@type': 'Offer', 'itemOffered': { '@type': 'Service', 'name': 'Ductless HVAC Repair', 'description': 'Expert repair services for mini split and ductless systems' } },
    ],
  },
  'sameAs': [site.social.facebook],
  'founder': site.founders.map((f) => ({ '@type': 'Person', 'name': f.name })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)} />
