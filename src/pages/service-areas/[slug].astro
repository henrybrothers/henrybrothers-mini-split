---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import WebPageSchema from '@/components/schema/WebPageSchema.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import { serviceAreas } from '@/data/serviceAreas';
import { site } from '@/data/site';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const pricing = await reader.singletons.membershipPricing.read();
const cleanCheckBase = pricing?.cleanAndCheckBasePrice ?? 99;

export function getStaticPaths() {
  return serviceAreas.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;

const pageUrl = `${site.url}/service-areas/${area.slug}`;
const metaTitle = `Mini Split Installation in ${area.city}, ${area.stateAbbr} | ${site.name}`;
const metaDesc = `${site.name} installs and services ductless mini splits in ${area.city}, ${area.state}. Expert local technicians. Free quotes. Financing available.`;

const breadcrumbs = [
  { name: 'Home', url: site.url },
  { name: 'Service Areas', url: `${site.url}/service-areas` },
  { name: `${area.city}, ${area.stateAbbr}`, url: pageUrl },
];

// Show up to 5 nearby areas (exclude current)
const nearbyAreas = serviceAreas
  .filter((a) => a.slug !== area.slug)
  .slice(0, 5);
---

<BaseLayout title={metaTitle} description={metaDesc} canonicalUrl={pageUrl}>
  <Fragment slot="head">
    <BreadcrumbSchema items={breadcrumbs} />
    <WebPageSchema name={metaTitle} description={metaDesc} url={pageUrl} />
    <LocalBusinessSchema
      overrideCity={area.city}
      overrideState={area.state}
      overrideStateAbbr={area.stateAbbr}
      overrideLat={area.geo.latitude}
      overrideLng={area.geo.longitude}
    />
  </Fragment>

  <!-- Hero -->
  <section class="py-16 md:py-20 bg-henry-navy text-vintage-cream distressed">
    <div class="container mx-auto px-4 relative z-10">
      <Breadcrumbs items={breadcrumbs} light={true} />
      <div class="mt-6">
        <span class="retro-badge text-sm mb-4">Service Area</span>
        <h1 class="font-heading font-extrabold text-3xl md:text-4xl mt-4 mb-4 vintage-text-shadow">
          Mini Split Installation in {area.city}, {area.stateAbbr}
        </h1>
        <p class="text-vintage-cream/80 max-w-2xl mb-8">{area.description}</p>
        <div class="flex flex-wrap gap-4">
          <a href="/#contact" class="btn-primary">Get a Free Quote</a>
          <a href={`tel:${site.phoneTel}`} class="border-2 border-henry-yellow text-henry-yellow font-bold py-3 px-6 hover:bg-henry-yellow hover:text-henry-navy transition-all">
            Call {site.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services in this area -->
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="section-title mb-4">What We Do in {area.city}</h2>
      <p class="text-henry-navy/70 mb-10">Full-service ductless HVAC for {area.city} homeowners and small businesses.</p>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {[
          { title: 'Mini Split Installation', desc: 'New single-zone or multi-zone ductless systems. We handle sizing, mounting, line sets, and startup.' },
          { title: 'Heating & Cooling Repair', desc: 'Fast diagnosis. Straight answers. No runaround. We repair any brand of ductless mini split.' },
          { title: 'Clean and Check℠', desc: `Our $${cleanCheckBase} maintenance visit — coil cleaning, filter check, refrigerant inspection, and full system test.` },
          { title: 'Free Quotes', desc: 'We walk your space, measure the rooms, and give you a detailed written quote at no charge.' },
          { title: 'Financing Available', desc: 'Partner with Acorn Finance for rates starting at 6.99% APR. Check your rate in minutes.' },
          { title: 'Smart Thermostat Setup', desc: 'Upgrade to smart controls for remote access, scheduling, and better efficiency.' },
        ].map((service) => (
          <div class="vintage-card">
            <h3 class="font-bold mb-1">{service.title}</h3>
            <p class="text-sm text-henry-navy/60">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-vintage-cream">
    <div class="container mx-auto px-4 max-w-2xl text-center">
      <h2 class="font-heading font-extrabold text-2xl md:text-3xl text-henry-navy mb-4">
        Ready for a Comfortable {area.city} Home?
      </h2>
      <p class="text-henry-navy/70 mb-8">
        Get a free, no-pressure quote from your local ductless HVAC experts. We serve {area.city} and
        communities throughout {area.county}.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/#contact" class="btn-primary">Request a Free Quote</a>
        <a href={`tel:${site.phoneTel}`} class="border-2 border-henry-navy text-henry-navy font-bold py-3 px-6 hover:bg-henry-navy hover:text-vintage-cream transition-all">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Nearby areas -->
  {nearbyAreas.length > 0 && (
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="font-heading font-bold text-xl mb-6">Other Areas We Serve</h2>
        <ul class="flex flex-wrap gap-3">
          {nearbyAreas.map((a) => (
            <li>
              <a
                href={`/service-areas/${a.slug}`}
                class="inline-block border-2 border-henry-navy/20 px-4 py-2 text-sm font-medium text-henry-navy hover:border-henry-yellow hover:text-henry-yellow transition-colors"
              >
                {a.city}, {a.stateAbbr}
              </a>
            </li>
          ))}
          <li>
            <a href="/service-areas" class="inline-block border-2 border-henry-navy/20 px-4 py-2 text-sm font-medium text-henry-navy hover:border-henry-yellow hover:text-henry-yellow transition-colors">
              View All Areas →
            </a>
          </li>
        </ul>
      </div>
    </section>
  )}
</BaseLayout>
