---
import { site } from '@/data/site';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const nap = await reader.singletons.businessInfo.read();

const phoneDisplay = nap?.phone ?? site.phone;
const phoneE164 = '+1' + phoneDisplay.replace(/\D/g, '');
const monSatHours = nap?.mondaySaturday ?? site.hours.weekday;
const sunHours = nap?.sunday ?? site.hours.sunday;
const serviceAreaNote = nap?.serviceAreaNote ?? 'Clark and Floyd Counties, Indiana';
---

<section id="contact" class="py-16 md:py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <span class="retro-badge text-sm mb-4">Let's Talk</span>
      <h2 class="section-title mt-6">Get In Touch</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <div class="bg-white p-6 md:p-8" style="box-shadow: 5px 5px 0 rgba(12,35,64,0.2);">
        <h3 class="font-heading font-bold text-xl mb-4">Send Us a Message</h3>
        <!-- TODO: Tally form ID (woQ0AV) may be changing — update when new form is ready -->
        <iframe
          data-tally-src="https://tally.so/embed/woQ0AV?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="500"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="Contact Henry Brothers"
          style="border: none; min-height: 400px;"
        ></iframe>
        <script>
          var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}
        </script>
      </div>

      <div class="bg-henry-navy text-vintage-cream p-6 md:p-8 h-fit" style="box-shadow: 5px 5px 0 rgba(12,35,64,0.4);">
        <h3 class="font-heading font-bold text-xl mb-6">Contact Information</h3>
        <div class="space-y-4">
          <a href={`tel:${phoneE164}`} class="flex items-center gap-3 text-vintage-cream/80 hover:text-henry-yellow transition-colors">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {phoneDisplay}
          </a>
          <a href={`mailto:${site.email}`} class="flex items-center gap-3 text-vintage-cream/80 hover:text-henry-yellow transition-colors">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {site.email}
          </a>
          <div class="flex items-start gap-3 text-vintage-cream/80">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>Serving {serviceAreaNote}</span>
          </div>
          <div class="flex items-start gap-3 text-vintage-cream/80">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div>
              <p>Mon–Sat: {monSatHours}</p>
              <p>Sun: {sunHours}</p>
            </div>
          </div>
        </div>
        <div class="mt-6 pt-4 border-t border-vintage-cream/20">
          <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-henry-yellow hover:underline text-sm">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
            Find us on Facebook
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
