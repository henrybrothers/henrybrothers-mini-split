---
import { site } from '@/data/site';
---

<section id="about" class="py-16 md:py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="retro-badge text-sm mb-4">Who We Are</span>
        <h2 class="section-title mt-6">About Henry Brothers</h2>
        <p class="text-henry-navy/80 mb-4">We're Justin and Nick Henry — brothers who grew up in Southern Indiana and decided to build something together. Henry Brothers Heat • Cool • Mini Splits started with a simple idea: bring straightforward, quality ductless heating and cooling service to our neighbors.</p>
        <p class="text-henry-navy/80 mb-6">We specialize in mini split systems because we believe they're the smartest way to heat and cool a home — efficient, quiet, and built for the way people actually live. Every install we do, we treat like it's our own house.</p>
        <blockquote class="border-l-4 border-henry-yellow pl-4 italic text-henry-navy/70 mb-8">
          "We're not just installing equipment — we're making sure our neighbors are comfortable in their homes, year-round."
          <cite class="block mt-2 not-italic font-bold text-henry-navy">— Justin Henry</cite>
        </blockquote>
        <div class="flex flex-wrap gap-6">
          <span class="flex items-center gap-2"><svg class="w-5 h-5 text-henry-yellow" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5C17.942 5.327 18 5.66 18 6c0 6-3.75 11-8 11S2 12 2 6c0-.34.058-.673.166-1.001zm5.541 3.708a1 1 0 00-1.414 1.414L8.586 12.414a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L9.293 10.293 7.707 8.707z" clip-rule="evenodd"/></svg><strong class="text-sm">Fully Insured</strong></span>
          <span class="flex items-center gap-2"><svg class="w-5 h-5 text-henry-yellow" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/></svg><strong class="text-sm">Fast Response</strong></span>
          <span class="flex items-center gap-2"><svg class="w-5 h-5 text-henry-yellow" fill="currentColor" viewBox="0 0 20 20"><path d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z"/></svg><strong class="text-sm">Satisfaction Guaranteed</strong></span>
        </div>
      </div>
      <div class="flex justify-center gap-6">
        <div class="vintage-border"><img src="/lovable-uploads/justin.jpg" alt="Justin Henry, co-founder of Henry Brothers Heat • Cool • Mini Splits" width="250" height="333" loading="lazy" class="w-full max-w-[250px]" /></div>
        <div class="vintage-border"><img src="/lovable-uploads/nick.jpg" alt="Nick Henry, co-founder of Henry Brothers Heat • Cool • Mini Splits" width="250" height="333" loading="lazy" class="w-full max-w-[250px]" /></div>
      </div>
    </div>
  </div>
</section>
