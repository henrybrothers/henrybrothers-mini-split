---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { site } from '@/data/site';

const pageUrl = `${site.url}/schedule`;
const breadcrumbs = [
  { name: 'Home', url: site.url },
  { name: 'Schedule Service', url: pageUrl },
];
---

<BaseLayout
  title={`Schedule HVAC Service | ${site.name}`}
  description={`Schedule a mini split installation, Clean and Check℠ maintenance visit, or repair service with ${site.name} in Charlestown, Indiana.`}
  canonicalUrl={pageUrl}
  noindex={true}
>
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <Breadcrumbs items={breadcrumbs} />
      <div class="text-center mb-10 mt-6">
        <span class="retro-badge text-sm mb-4">Book Now</span>
        <h1 class="section-title mt-6">Schedule Service</h1>
        <p class="text-henry-navy/70 max-w-xl mx-auto">
          Use the form below to request a service visit. We'll follow up to confirm your appointment.
          Questions? Call us at <a href={`tel:${site.phoneTel}`} class="font-bold text-henry-navy hover:text-henry-yellow transition-colors">{site.phone}</a>.
        </p>
      </div>

      <div class="vintage-card p-6 md:p-8">
        <!-- Tally embed for conditional scheduling flow -->
        <iframe
          data-tally-src="https://tally.so/embed/wMzVBz?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="500"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="Schedule HVAC Service with Henry Brothers"
          style="border: none; min-height: 500px;"
        ></iframe>
        <script>
          var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}
        </script>
      </div>
    </div>
  </section>
</BaseLayout>
