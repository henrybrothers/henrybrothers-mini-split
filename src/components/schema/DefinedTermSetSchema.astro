---
import { site } from '@/data/site';
import { dictionaryTerms } from '@/data/dictionaryTerms';

const data = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": `${site.name} Dictionary`,
  "description": "HVAC terms explained the way your neighbor would — no jargon, no fluff. A plain-spoken glossary from Henry Brothers.",
  "url": `${site.url}/dictionary`,
  "hasDefinedTerm": dictionaryTerms.map((t) => ({ "@type": "DefinedTerm", "name": t.title, "url": `${site.url}/dictionary/${t.slug}` })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)} />
