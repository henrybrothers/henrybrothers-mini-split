---
interface Item { name: string; url: string; }
interface Props { items: Item[]; }
const { items } = Astro.props;
const data = { "@context": "https://schema.org", "@type": "ItemList", "numberOfItems": items.length, "itemListElement": items.map((item, i) => ({ "@type": "ListItem", "position": i + 1, "name": item.name, "url": item.url })) };
---
<script type="application/ld+json" set:html={JSON.stringify(data)} />
