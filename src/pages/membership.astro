---
export const prerender = true;
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import membershipBadge from '/public/images/henrybros-two-seasons-membership.webp';
import { site } from '@/data/site';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const pricing = await reader.singletons.membershipPricing.read();

const cleanCheckBase = pricing?.cleanAndCheckBasePrice ?? 99;
const cleanCheckFull = pricing?.cleanAndCheckPrice ?? 199;
const membershipPrice = pricing?.membershipPrice ?? 159;

const included = [
  'Full system inspection',
  'Coil cleaning (indoor and outdoor)',
  'Filter check and replacement recommendation',
  'Refrigerant level check',
  'Electrical connection inspection',
  'Thermostat calibration',
  'Performance and efficiency test',
];

const faqs = [
  {
    q: 'What if I need a repair between visits?',
    a: 'Members get 10% off all repairs, all year. Call us, we come out, and your discount applies automatically. No hoops.',
  },
  {
    q: 'When do the two visits happen?',
    a: 'We schedule one in spring before cooling season and one in fall before heating season. We\'ll reach out to set up both.',
  },
  {
    q: 'What\'s the difference between Clean and Check℠ and the membership?',
    a: `Clean and Check℠ is a single visit at $${cleanCheckBase}. The Two Seasons Membership is $${membershipPrice}/year — that covers both visits plus the repair discount. If you're already paying $${cleanCheckBase} once, the second visit costs you $${membershipPrice - cleanCheckBase} more. That's the math.`,
  },
  {
    q: 'Does the membership auto-renew?',
    a: "We'll reach out before renewal. Nothing charges automatically without a conversation first.",
  },
];
---

<BaseLayout
  title={`Maintenance Membership | ${site.name} | Southern Indiana`}
  description={`Clean and Check℠ or Two Seasons Membership — keep your mini split running right in Clark and Floyd County, Indiana.`}
  canonicalUrl={`${site.url}/membership`}
>

  {/* Hero */}
  <section class="relative bg-henry-navy text-vintage-cream py-16 md:py-24 vintage-texture distressed overflow-hidden">
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-2xl">
        <span class="retro-badge text-sm mb-4 inline-block">Maintenance Plans</span>
        <h1 class="font-heading font-extrabold text-4xl md:text-5xl leading-tight mb-6 vintage-text-shadow mt-4">
          Keep Your System Running.<br />
          <span class="text-henry-yellow">Skip the Surprise Breakdowns.</span>
        </h1>
        <p class="text-lg text-vintage-cream/90 mb-8 max-w-xl">
          One tune-up or two. Southern Indiana summers and winters don't care what your system looks like inside — we do.
          Pick the plan that fits and we'll handle the rest.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#pricing" class="btn-primary">See Plans</a>
          <a href={`tel:${site.phoneTel}`} class="border-2 border-henry-yellow text-henry-yellow font-bold py-3 px-6 hover:bg-henry-yellow hover:text-henry-navy transition-all">
            Call {site.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Pricing Cards */}
  <section id="pricing" class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="section-title">Two Plans. One Goal.</h2>
        <p class="text-henry-navy/70 max-w-xl mx-auto">Pick a single visit or get both seasons covered. Either way, you get the same thorough Clean and Check℠ service.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">

        {/* Tier 1 */}
        <div class="vintage-card flex flex-col">
          <div class="mb-6">
            <span class="inline-block bg-henry-navy/10 text-henry-navy text-xs font-bold uppercase tracking-widest px-3 py-1 mb-4">Single Visit</span>
            <h3 class="font-heading font-extrabold text-2xl mb-1">Clean and Check℠</h3>
            <p class="text-henry-navy/70 text-sm mb-4">One seasonal tune-up. In, done, gone.</p>
            <div class="border-t border-henry-navy/10 pt-4">
              <div class="flex items-end gap-2 mb-1">
                <span class="font-heading font-extrabold text-4xl text-henry-navy">${cleanCheckBase}</span>
                <span class="text-henry-navy/60 text-sm pb-1">per visit</span>
              </div>
              <p class="text-henry-navy/60 text-sm">or ${cleanCheckFull} with Ecobee smart thermostat install</p>
            </div>
          </div>
          <a href="/schedule" class="mt-auto border-2 border-henry-navy text-henry-navy font-bold py-3 px-6 text-center hover:bg-henry-navy hover:text-vintage-cream transition-all">
            Schedule a Visit
          </a>
        </div>

        {/* Tier 2 */}
        <div class="relative flex flex-col bg-henry-navy text-vintage-cream p-6 md:p-8 border-4 border-henry-yellow" style="box-shadow: 6px 6px 0 rgba(230,179,0,0.4);">
          <div class="absolute -top-4 left-6">
            <span class="bg-henry-yellow text-henry-navy text-xs font-bold uppercase tracking-widest px-3 py-1">Best Value</span>
          </div>
          <div class="mb-6 mt-2">
            <div class="flex items-start gap-4 mb-4">
              <Image
                src={membershipBadge}
                alt="Two Seasons Membership badge"
                width={80}
                height={80}
                class="flex-shrink-0 rounded-lg"
              />
              <div>
                <span class="inline-block bg-henry-yellow/20 text-henry-yellow text-xs font-bold uppercase tracking-widest px-3 py-1 mb-2">Annual Membership</span>
                <h3 class="font-heading font-extrabold text-2xl">Two Seasons Membership</h3>
                <p class="text-vintage-cream/80 text-sm mt-1">Spring + fall visits, plus 10% off all repairs year-round.</p>
              </div>
            </div>
            <div class="border-t border-vintage-cream/20 pt-4">
              <div class="flex items-end gap-2 mb-1">
                <span class="font-heading font-extrabold text-4xl text-henry-yellow">${membershipPrice}</span>
                <span class="text-vintage-cream/60 text-sm pb-1">/ year</span>
              </div>
              <p class="text-henry-yellow/80 text-sm font-medium">
                Already paying ${cleanCheckBase} for one visit? Add both seasons for ${membershipPrice - cleanCheckBase} more — plus the repair discount.
              </p>
            </div>
          </div>
          <a href="/schedule" class="mt-auto btn-primary text-center">
            Join the Membership
          </a>
        </div>

      </div>
    </div>
  </section>

  {/* What's Included */}
  <section class="py-16 md:py-20 bg-stone-50">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="section-title">What Happens Each Visit</h2>
          <p class="text-henry-navy/70">Every Clean and Check℠ — whether it's your first or your fourth — covers all of this.</p>
        </div>
        <ul class="space-y-3">
          {included.map((item) => (
            <li class="flex items-start gap-3 bg-white border border-henry-navy/10 px-5 py-4">
              <svg class="w-5 h-5 text-henry-yellow flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              <span class="font-medium text-henry-navy">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* 10% Repair Discount Callout */}
  <section class="py-14 bg-henry-yellow">
    <div class="container mx-auto px-4 text-center">
      <p class="text-henry-navy text-sm font-bold uppercase tracking-widest mb-2">Members Only</p>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-henry-navy mb-4">
        10% Off Every Repair. All Year.
      </h2>
      <p class="text-henry-navy/80 max-w-xl mx-auto">
        Something breaks in July? Call us. Your membership discount applies to parts and labor, no questions asked.
        Our Transparent Pricebook™ means you see the price before we touch anything.
      </p>
    </div>
  </section>

  {/* FAQ */}
  <section class="py-16 md:py-20 bg-white">
    <div class="container mx-auto px-4 max-w-2xl">
      <div class="text-center mb-10">
        <h2 class="section-title">Questions</h2>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <div class="vintage-card">
            <h3 class="font-heading font-bold text-lg mb-2">{faq.q}</h3>
            <p class="text-henry-navy/70">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-16 md:py-20 bg-henry-navy text-vintage-cream text-center distressed">
    <div class="container mx-auto px-4 relative z-10">
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl mb-4 vintage-text-shadow">
        Ready to Lock In Your Service?
      </h2>
      <p class="text-vintage-cream/80 max-w-xl mx-auto mb-8">
        Clark County. Floyd County. Southern Indiana. We're close, we're available, and we'll get it right.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/schedule" class="btn-primary">Schedule Service</a>
        <a href={`tel:${site.phoneTel}`} class="border-2 border-henry-yellow text-henry-yellow font-bold py-3 px-6 hover:bg-henry-yellow hover:text-henry-navy transition-all">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
