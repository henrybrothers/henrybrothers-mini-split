---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import OrganizationSchema from '@/components/schema/OrganizationSchema.astro';
import WebSiteSchema from '@/components/schema/WebSiteSchema.astro';
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import ReviewSchema from '@/components/schema/ReviewSchema.astro';
import Hero from '@/components/Hero.astro';
import Services from '@/components/Services.astro';
import About from '@/components/About.astro';
import ServiceAreas from '@/components/ServiceAreas.astro';
import CleanCheck from '@/components/CleanCheck.astro';
import Financing from '@/components/Financing.astro';
import CTA from '@/components/CTA.astro';
import Contact from '@/components/Contact.astro';
import { site } from '@/data/site';

const breadcrumbs = [{ name: 'Home', url: site.url }];
---

<BaseLayout
  title={`Mini Split Installation & Repair | ${site.name} | Charlestown, IN`}
  description={site.description}
  canonicalUrl={site.url}
>
  <Fragment slot="head">
    <LocalBusinessSchema />
    <OrganizationSchema />
    <WebSiteSchema />
    <BreadcrumbSchema items={breadcrumbs} />
    <ReviewSchema />
  </Fragment>

  <Hero />
  <Services />
  <About />
  <ServiceAreas />
  <CleanCheck />
  <Financing />
  <CTA />
  <Contact />
</BaseLayout>
