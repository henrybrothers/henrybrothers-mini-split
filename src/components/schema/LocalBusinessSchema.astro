---
import { site } from '@/data/site';
import { serviceAreas } from '@/data/serviceAreas';

interface Props {
  overrideCity?: string;
  overrideState?: string;
  overrideStateAbbr?: string;
  overrideLat?: number;
  overrideLng?: number;
}

const {
  overrideCity,
  overrideState,
  overrideStateAbbr,
  overrideLat,
  overrideLng,
} = Astro.props;

const city = overrideCity ?? site.address.city;
const state = overrideStateAbbr ?? site.address.state;
const lat = overrideLat ?? site.geo.latitude;
const lng = overrideLng ?? site.geo.longitude;

const data = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": site.url,
  "name": site.name,
  "alternateName": site.shortName,
  "description": site.description,
  "url": site.url,
  "telephone": site.phoneTel,
  "email": site.email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": city,
    "addressRegion": state,
    "postalCode": site.address.zip,
    "addressCountry": site.address.country,
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": lat,
    "longitude": lng,
  },
  "areaServed": serviceAreas.map((a) => ({
    "@type": "City",
    "name": a.city,
    "addressRegion": a.state,
  })),
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": { "@type": "GeoCoordinates", "latitude": site.geo.latitude, "longitude": site.geo.longitude },
    "geoRadius": site.serviceRadius,
  },
  "openingHours": site.hours.schema,
  "priceRange": "$$",
  "paymentAccepted": "Cash, Credit Card, Check, Financing Available",
  "currenciesAccepted": "USD",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "3", "bestRating": "5", "worstRating": "1" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "HVAC Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mini Split Installation", "description": "Professional installation of ductless mini split systems" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "HVAC Maintenance & Clean and Check℠", "description": "Regular maintenance and tune-up service" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "HVAC Repair", "description": "Expert repair services for ductless and mini split systems" } },
    ],
  },
  "sameAs": [site.social.facebook],
  "founder": site.founders.map((f) => ({ "@type": "Person", "name": f.name })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(data)} />
