---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import { site } from '@/data/site';

const reader = createReader(process.cwd(), keystaticConfig);
const siteSettings = await reader.singletons.siteSettings.read();
const footerTagline = siteSettings?.footerTagline ?? 'Ductless HVAC experts serving Clark County and Floyd County, Indiana.';

const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Services', href: '/#services' },
  { label: 'About', href: '/#about' },
  { label: 'Service Areas', href: '/service-areas' },
  { label: 'Clean and Check℠', href: '/#clean-check' },
  { label: 'Financing', href: '/#financing' },
  { label: 'Contact', href: '/#contact' },
  { label: 'Dictionary', href: '/dictionary' },
];
---

<footer class="bg-henry-navy text-vintage-cream py-12">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href="/">
          <img src="/images/Website_Header_Logo.png" alt={site.name} width="126" height="75" class="h-14 w-auto mb-4" loading="lazy" />
        </a>
        <p class="text-vintage-cream/80 text-sm mb-4">{footerTagline}</p>
        <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-henry-yellow hover:underline" aria-label="Henry Brothers on Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          Follow us on Facebook
        </a>
      </div>

      <div>
        <h3 class="font-heading font-bold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li><a href={link.href} class="text-vintage-cream/80 hover:text-henry-yellow transition-colors text-sm">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-heading font-bold text-lg mb-4">Contact</h3>
        <div class="space-y-3 text-sm">
          <a href={`tel:${site.phoneTel}`} class="flex items-center gap-2 text-vintage-cream/80 hover:text-henry-yellow transition-colors">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {site.phone}
          </a>
          <a href={`mailto:${site.email}`} class="flex items-center gap-2 text-vintage-cream/80 hover:text-henry-yellow transition-colors">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {site.email}
          </a>
          <p class="text-vintage-cream/80">
            <strong class="text-vintage-cream">Hours:</strong><br/>
            Mon–Fri: {site.hours.weekday}<br/>
            Sat: {site.hours.saturday}<br/>
            Sun: {site.hours.sunday}
          </p>
        </div>
      </div>
    </div>

    <div class="border-t border-vintage-cream/20 mt-8 pt-6 text-center text-xs text-vintage-cream/60">
      <p>&copy; {currentYear} {site.name}. All rights reserved.</p>
      <p class="mt-1">Clean and Check℠ is a service mark of {site.name}.</p>
    </div>
  </div>
</footer>
